-- ดึงชื่อลูกค้า
SELECT 
  customerid,
  firstname,
  country,
  COUNT (*) OVER() AS window_function
  -- 'OVER' Is Window functions
FROM customers;

-- row_number  in Window functions

SELECT 
  ROW_NUMBER () OVER() AS row_numb,
  firstname, 
  country
FROM customers;
