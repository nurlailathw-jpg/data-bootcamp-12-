/*
  How different between 
  window vs. aggregate functions 
    * Window functions: make a new column, create a new analytic column
      - row number
      - rank 
      - dense rank 
      - NTILE (for making segmentation)
    * Aggregate functions: Is Aggregate Column to Single Value
*/

Aggregate functions
SELECT 
  COUNT (*), -- นับจำนวนแถวทั้งหมด
  COUNT(Customerid),  -- COUNT comum อาจมี missing valua ได้ , จะไม่ได้ = count * 
  COUNT(company) , 
  COUNT (*) - COUNT (company) 
  AS  missing_data -- COUNT (*) - COUNT (colum) = missing valua (NULL)
FROM customers;

-- WHERE clause to filter  NULL, missing values 
SELECT * FROM customers 
WHERE company IS NOT NULL ;

SELECT * FROM customers 
WHERE company IS  NULL;

